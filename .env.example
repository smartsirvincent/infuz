# 必要：文案生成 (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# 可選：AI 圖片生成 (https://kie.ai)
KIE_API_KEY=

# 可選：圖片/xlsx 轉存到 Cloudinary 拿永久 URL (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# 或 unsigned 模式(需在 Cloudinary dashboard 開 preset)
# CLOUDINARY_UPLOAD_PRESET=

# 可選：覆寫使用的 Claude 模型,預設 claude-sonnet-4-5
# CLAUDE_MODEL=claude-opus-4-7
